APP_NAME=order

SERVER_PORT=8080

ROOT_LOG_LEVEL=INFO
APP_LOG_LEVEL=INFO

DB_URL=jdbc:postgresql://postgres:5432/order
DB_USERNAME=order
DB_PASSWORD=order

POSTGRES_DB=order
POSTGRES_USER=order
POSTGRES_PASSWORD=order

FLYWAY_ENABLED=true

ORDER_PROCESSING_CRON=0 */5 * * * *

KNOWLEDGE_BASE_RESOURCE=knowledge_base.json
OPENAI_BASE_URL=http://openai-mock:8080/v1
OPENAI_API_KEY=test-key
SPRING_AI_CHAT_MODEL_PROVIDER=openai

AI_PROVIDER=openai
AI_MODEL=gpt-4.1-mini
AI_TIMEOUT=PT20S

APP_MEMORY_LIMIT=1g
APP_JAVA_TOOL_OPTIONS=-XX:InitialRAMPercentage=25 -XX:MaxRAMPercentage=75 -XX:MaxMetaspaceSize=256m
WIREMOCK_MEMORY_LIMIT=384m
WIREMOCK_JAVA_OPTS=-Xms64m -Xmx256m -XX:MaxMetaspaceSize=128m

LOGGING_FILE_NAME=/var/log/order/application.log
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
